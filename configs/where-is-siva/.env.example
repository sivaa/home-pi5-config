# Where Is Siva - environment config
# Copy to /opt/where-is-siva/.env and fill in values
# DO NOT commit the real .env to git

# Garmin MapShare KML feed URL (contains username - keep secret)
GARMIN_FEED_URL=https://share.garmin.com/Feed/Share/YOUR_MAPSHARE_NAME

# Git push to public repo for Vercel auto-deploy
GIT_PUSH_ENABLED=true
GIT_REPO_PATH=/opt/where-is-siva/public-repo
